# ═══════════════════════════════════════════════════════════════════════════
# MODULE 5 – METAHEURISTIC THRESHOLD OPTIMISATION  (Eq. 9)
# ═══════════════════════════════════════════════════════════════════════════
#
#   Eq. 9:  θ* = argmax_θ  F(θ)
#           F(θ) = w1·DR(θ) − w2·FPR(θ) − w3·C(θ)
#           s.t.  w1+w2+w3=1,  DR ≥ δ_DR,  FPR ≤ δ_FPR
#
# In offensive context: θ is the Jaccard anomaly threshold used to
# trigger an alert/escalation during automated fuzzing campaigns.
# ═══════════════════════════════════════════════════════════════════════════

@dataclass
class OptConfig:
    w1: float = 0.5          # weight: detection rate
    w2: float = 0.3          # weight: false-positive rate
    w3: float = 0.2          # weight: compute cost
    delta_dr: float = 0.85   # min acceptable DR
    delta_fpr: float = 0.10  # max acceptable FPR
    theta_min: float = 0.0
    theta_max: float = 1.0


def F(theta: float,
      dr_fn: Callable[[float], float],
      fpr_fn: Callable[[float], float],
      cost_fn: Callable[[float], float],
      cfg: OptConfig) -> Optional[float]:
    """Objective function – returns None if constraints violated."""
    dr, fpr, cost = dr_fn(theta), fpr_fn(theta), cost_fn(theta)
    if dr < cfg.delta_dr or fpr > cfg.delta_fpr:
        return None
    return cfg.w1 * dr - cfg.w2 * fpr - cfg.w3 * cost


# ── PSO ────────────────────────────────────────────────────────────────────

def pso(dr_fn, fpr_fn, cost_fn, cfg: OptConfig,
        n: int = 40, iters: int = 150,
        w: float = 0.72, c1: float = 1.49, c2: float = 1.49
        ) -> Tuple[float, float]:
    """Particle Swarm Optimisation for θ*."""
    pos = [random.uniform(cfg.theta_min, cfg.theta_max) for _ in range(n)]
    vel = [0.0] * n
    pbest = pos[:]
    pbest_score = [F(p, dr_fn, fpr_fn, cost_fn, cfg) or -1e9 for p in pos]

    gbest = pbest[pbest_score.index(max(pbest_score))]
    gbest_score = max(pbest_score)

    for _ in range(iters):
        for i in range(n):
            r1, r2 = random.random(), random.random()
            vel[i] = (w * vel[i]
                      + c1 * r1 * (pbest[i] - pos[i])
                      + c2 * r2 * (gbest     - pos[i]))
            pos[i] = max(cfg.theta_min,
                         min(cfg.theta_max, pos[i] + vel[i]))
            s = F(pos[i], dr_fn, fpr_fn, cost_fn, cfg) or -1e9
            if s > pbest_score[i]:
                pbest[i], pbest_score[i] = pos[i], s
            if s > gbest_score:
                gbest, gbest_score = pos[i], s

    return gbest, gbest_score


# ── GWO ────────────────────────────────────────────────────────────────────

def gwo(dr_fn, fpr_fn, cost_fn, cfg: OptConfig,
        n: int = 40, iters: int = 150) -> Tuple[float, float]:
    """Grey Wolf Optimiser for θ* (Mirjalili et al. 2014)."""
    wolves = [random.uniform(cfg.theta_min, cfg.theta_max) for _ in range(n)]
    scored = lambda w: F(w, dr_fn, fpr_fn, cost_fn, cfg) or -1e9

    alpha, beta, delta = sorted(wolves, key=scored, reverse=True)[:3]
    alpha_s = scored(alpha)

    for it in range(iters):
        a = 2.0 * (1 - it / iters)   # decreases 2 → 0
        new_wolves = []
        for w in wolves:
            X1 = alpha - a * abs(2*random.random()*alpha - w) * (2*random.random()-1)
            X2 = beta  - a * abs(2*random.random()*beta  - w) * (2*random.random()-1)
            X3 = delta - a * abs(2*random.random()*delta - w) * (2*random.random()-1)
            new_w = max(cfg.theta_min,
                        min(cfg.theta_max, (X1 + X2 + X3) / 3))
            new_wolves.append(new_w)
        wolves = new_wolves
        top3 = sorted(wolves, key=scored, reverse=True)[:3]
        alpha, beta, delta = top3
        alpha_s = scored(alpha)

    return alpha, alpha_s


