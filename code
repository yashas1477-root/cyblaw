OUTCOMES = ("ACCEPT", "REJECT", "CRASH", "TIMEOUT")

@dataclass
class Cert:
    data: bytes
    label: str = ""
    def __hash__(self):  return hash(self.data)
    def __eq__(self, o): return isinstance(o, Cert) and self.data == o.data

ValidatorFn = Callable[[Cert], str]


# ═══════════════════════════════════════════════════════════════════════════
# MODULE 1 – DIFFERENTIAL FUZZING OBJECTIVE  (Eq. 1 & 2)
# ═══════════════════════════════════════════════════════════════════════════
#
#   Eq. 1 : max  |{ R(I_k, c*)  :  k ∈ [n] }|
#   Eq. 2 :      ∃ I_j, I_k  :  R(I_j, c*) ≠ R(I_k, c*)
#
# Strategy: feed the same malformed certificate to N validators,
# collect outcomes, flag any disagreement as a potential vuln.
# ═══════════════════════════════════════════════════════════════════════════

def run_disagreement(validators: Dict[str, ValidatorFn],
                     cert: Cert) -> Tuple[int, Dict[str, str]]:
    """
    Eq. 1 – returns (distinct_outcome_count, {name: outcome}).
    score > 1  →  Eq. 2 satisfied  →  parsing divergence found.
    """
    results = {name: fn(cert) for name, fn in validators.items()}
    return len(set(results.values())), results


def sweep_corpus(validators: Dict[str, ValidatorFn],
                 corpus: List[Cert]) -> List[Tuple[Cert, Dict[str, str]]]:
    """
    Run all validators over every cert in corpus.
    Returns list of (cert, results) where divergence was detected.
    """
    hits = []
    for cert in corpus:
        score, results = run_disagreement(validators, cert)
        if score > 1:
            hits.append((cert, results))
    return hits


# ── Real-world validator wrappers (subprocess-based) ──────────────────────

def openssl_validator(cert: Cert) -> str:
    """
    Invoke system OpenSSL to validate DER-encoded cert bytes.
    Requires: openssl CLI installed.
    """
    import tempfile
    with tempfile.NamedTemporaryFile(suffix=".der", delete=False) as f:
        f.write(cert.data)
        tmp = f.name
    try:
        result = subprocess.run(
            ["openssl", "x509", "-in", tmp, "-inform", "DER",
             "-noout", "-text"],
            capture_output=True, timeout=5
        )
        if result.returncode == 0:
            return "ACCEPT"
        stderr = result.stderr.decode(errors="replace").lower()
        if "unable to load" in stderr or "error" in stderr:
            return "REJECT"
        return "REJECT"
    except subprocess.TimeoutExpired:
        return "TIMEOUT"
    except Exception:
        return "CRASH"
    finally:
        os.unlink(tmp)


# ── DER / ASN.1 Corpus Generators (edge-case inputs from §V TCEV-2) ──────

def generate_edge_case_certs() -> List[Cert]:
    """
    Produces malformed DER structures that target TCEV-2 parsing logic.
    Each cert targets a known divergence class.
    """
    certs = []

    # 1. Null-byte injection in the certificate body (Common Name exploit)
    certs.append(Cert(
        b"\x30\x82\x01\x00" + b"\x00" * 10 + b"\xff" * 20,
        "null_byte_injection"
    ))
    # 2. Non-DER BER encoding (indefinite length)
    certs.append(Cert(
        b"\x30\x80" + b"\x02\x01\x01" + b"\x00\x00",
        "ber_indefinite_length"
    ))
    # 3. Negative serial number
    certs.append(Cert(
        b"\x30\x0f\x02\x04\xff\x00\x00\x01" + b"\x30\x07" + b"\x00" * 7,
        "negative_serial"
    ))
    # 4. Zero-length subject field
    certs.append(Cert(
        b"\x30\x06\x30\x00\x03\x02\x00\x00",
        "zero_length_subject"
    ))
    # 5. Oversized certificate (overflow trigger)
    certs.append(Cert(
        b"\x30\x84\xff\xff\xff\xff" + os.urandom(512),
        "length_overflow"
    ))
    # 6. Unknown critical extension
    certs.append(Cert(
        b"\x30\x15\x06\x03\x55\x04\x03\x01\x01\xff" + b"\x55" * 11,
        "unknown_critical_extension"
    ))
    # 7. Path-length constraint abuse
    certs.append(Cert(
        b"\x30\x09\x30\x07\x01\x01\xff\x02\x02\x00\x00",
        "path_length_constraint_abuse"
    ))
    return certs


# ═══════════════════════════════════════════════════════════════════════════
# MODULE 2 – CGF ENERGY / MARKOV CHAIN  (Eq. 3 & 4)
# ═══════════════════════════════════════════════════════════════════════════
#
#   Eq. 3 : E(s)    = α / ρ(p(s))
#   Eq. 4 : ρ(p)    = |{s' ∈ S : p(s')=p}| / |S|
#
# Rare execution paths get high energy → more mutations.
# ═══════════════════════════════════════════════════════════════════════════

@dataclass
class FuzzSeed:
    cert: Cert
    path_id: str = ""
    mutations_applied: int = 0


def compute_path_id(cert: Cert) -> str:
    """SHA-1 prefix as a proxy execution-path fingerprint."""
    return hashlib.sha1(cert.data).hexdigest()[:12]


def path_density(seed: FuzzSeed, pool: List[FuzzSeed]) -> float:
    """Eq. 4 – fraction of seeds sharing this path."""
    if not pool:
        return 0.0
    return sum(1 for s in pool if s.path_id == seed.path_id) / len(pool)


def seed_energy(seed: FuzzSeed, pool: List[FuzzSeed],
                alpha: float = 1.0) -> float:
    """Eq. 3 – rare paths → high energy → prioritised for mutation."""
    rho = path_density(seed, pool)
    return alpha / rho if rho > 0 else float("inf")


# ── Mutation strategies targeting X.509 parse surfaces ──────────────────

def mutate(cert: Cert, strategy: str = "random") -> Cert:
    data = bytearray(cert.data)
    n = len(data)
    if n == 0:
        return cert

    if strategy == "random":
        # Flip random bytes
        for i in random.sample(range(n), k=max(1, n // 20)):
            data[i] ^= random.randint(1, 255)

    elif strategy == "length_tamper":
        # Overwrite length fields (bytes 2–5 in DER TLV)
        if n > 5:
            for i in range(1, min(6, n)):
                data[i] = random.randint(0, 255)

    elif strategy == "tag_flip":
        # Flip ASN.1 tag bytes (every 4th byte is likely a tag)
        for i in range(0, n, 4):
            data[i] ^= 0x20  # toggle constructed bit

    elif strategy == "null_inject":
        # Insert null bytes at random positions
        pos = random.randint(0, n - 1)
        data[pos] = 0x00

    return Cert(bytes(data), cert.label + f"_{strategy}")


STRATEGIES = ["random", "length_tamper", "tag_flip", "null_inject"]


def cgf_fuzz_loop(validators: Dict[str, ValidatorFn],
                  initial_corpus: List[Cert],
                  iterations: int = 200,
                  alpha: float = 1.0) -> List[Tuple[Cert, Dict[str, str]]]:
    """
    Full CGF loop (Eq. 3–4).
    Returns all (cert, validator_results) pairs where divergence found.
    """
    pool: List[FuzzSeed] = [
        FuzzSeed(cert=c, path_id=compute_path_id(c))
        for c in initial_corpus
    ]
    divergent: List[Tuple[Cert, Dict[str, str]]] = []

    for i in range(iterations):
        # Energy-weighted seed selection
        energies = [min(seed_energy(s, pool, alpha), 1e6) for s in pool]
        total = sum(energies)
        probs = [e / total for e in energies]
        chosen = random.choices(pool, weights=probs, k=1)[0]

        # Pick mutation strategy (rotate through all)
        strategy = STRATEGIES[i % len(STRATEGIES)]
        mutant = mutate(chosen.cert, strategy)
        new_seed = FuzzSeed(cert=mutant, path_id=compute_path_id(mutant))
        pool.append(new_seed)

        # Check for disagreement
        score, results = run_disagreement(validators, mutant)
        if score > 1:
            divergent.append((mutant, results))

    return divergent


# ═══════════════════════════════════════════════════════════════════════════
# MODULE 3 – JACCARD DISTANCE METRIC  (Eq. 5 & 6)
# ═══════════════════════════════════════════════════════════════════════════
#
#   Eq. 5 : J(Ij,Ik)   = |Aj ∩ Ak| / |Aj ∪ Ak|
#   Eq. 6 : D_J(Ij,Ik) = 1 − J
#
#   Decision boundary (paper §IV.C):
#     D_J ∈ [0.22,0.35] → shallow fuzzers / minor inconsistency
#     D_J ∈ [0.68,0.81] → deep fuzzers  / exploitable gap
#     D_J ≈ 0.50        → security boundary
# ═══════════════════════════════════════════════════════════════════════════

BOUNDARY = 0.50

def jaccard_distance(a: Set, b: Set) -> float:
    """Eq. 6 – D_J(Ij, Ik)."""
    if not a and not b:
        return 0.0
    union = len(a | b)
    return len(a ^ b) / union if union else 0.0


def risk_label(dj: float) -> str:
    if dj < 0.35:   return "LOW    – minor parsing quirk"
    if dj < 0.50:   return "MEDIUM – approaching security boundary"
    if dj < 0.68:   return "HIGH   – security boundary exceeded"
    return              "CRITICAL – systematically exploitable gap"


def pairwise_jaccard_matrix(validators: Dict[str, ValidatorFn],
                             corpus: List[Cert]
                             ) -> Dict[Tuple[str, str], float]:
    """
    Build the full D_J matrix for all validator pairs.
    Acceptance sets are computed over the provided corpus.
    """
    acceptance: Dict[str, Set[Cert]] = {n: set() for n in validators}
    for cert in corpus:
        for name, fn in validators.items():
            if fn(cert) == "ACCEPT":
                acceptance[name].add(cert)

    from itertools import combinations
    return {
        (n1, n2): jaccard_distance(acceptance[n1], acceptance[n2])
        for n1, n2 in combinations(validators, 2)
    }


def print_jaccard_report(matrix: Dict[Tuple[str, str], float]):
    print("\n── Jaccard Distance Matrix (Eq. 5–6) ──────────────────────")
    for (v1, v2), dj in sorted(matrix.items(), key=lambda x: -x[1]):
        bar = "█" * int(dj * 30)
        print(f"  {v1:12s} ↔ {v2:12s}  D_J={dj:.4f}  {bar}")
        print(f"  {'':>27}  Risk: {risk_label(dj)}")


# ═══════════════════════════════════════════════════════════════════════════
# MODULE 4 – DIRECTED GREYBOX FUZZING DISTANCE  (Eq. 7 & 8)
# ═══════════════════════════════════════════════════════════════════════════
#
#   Eq. 7 : d_f(b,T)  = (1/|T|) * Σ_{t∈T} d(b,t)   [block→target mean]
#   Eq. 8 : d_s(s,T)  = (1/|s|) * Σ_{b∈s} d_f(b,T) [seed trace mean]
#
# Use: prioritise seeds whose execution traces are closest to
# dangerous parse functions (e.g. validate_san, parse_extensions).
# ═══════════════════════════════════════════════════════════════════════════

CallGraph = Dict[str, List[str]]


def bfs_distance(graph: CallGraph, start: str, end: str,
                 sentinel: int = 100) -> int:
    """BFS shortest path; returns sentinel if unreachable."""
    if start == end:
        return 0
    visited, queue = {start}, [(start, 0)]
    while queue:
        node, depth = queue.pop(0)
        for nb in graph.get(node, []):
            if nb == end:
                return depth + 1
            if nb not in visited:
                visited.add(nb)
                queue.append((nb, depth + 1))
    return sentinel


def block_distance(block: str, targets: List[str],
                   graph: CallGraph) -> float:
    """Eq. 7 – mean distance from block to all targets."""
    if not targets:
        return 0.0
    return sum(bfs_distance(graph, block, t) for t in targets) / len(targets)


def seed_distance(trace: List[str], targets: List[str],
                  graph: CallGraph) -> float:
    """Eq. 8 – mean block distance of a seed's execution trace."""
    if not trace:
        return float("inf")
    return sum(block_distance(b, targets, graph) for b in trace) / len(trace)


def rank_seeds_by_distance(seeds_with_traces: List[Tuple[FuzzSeed, List[str]]],
                            targets: List[str],
                            graph: CallGraph
                            ) -> List[Tuple[float, FuzzSeed]]:
    """
    Rank seeds: lowest d_s = closest to vulnerable code = highest priority.
    """
    ranked = [
        (seed_distance(trace, targets, graph), seed)
        for seed, trace in seeds_with_traces
    ]
    return sorted(ranked, key=lambda x: x[0])


